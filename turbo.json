{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", ".next/**"],
      "cache": true
    },
    "typecheck": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": [],
      "env": ["DATABASE_URL", "T3X_TEST_PG_PORT"],
      "cache": true
    },
    "lint": {
      "outputs": [],
      "cache": true
    },
    "dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true,
      "env": ["AUTH_DISABLED", "NEXT_PUBLIC_API_URL", "NEXT_PUBLIC_AUTH_DISABLED"]
    },
    "clean": {
      "cache": false
    }
  }
}
