{
  "$schema": "https://biomejs.dev/schemas/2.3.10/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": false,
    "includes": [
      "**",
      "!**/node_modules",
      "!**/dist",
      "!**/.next",
      "!**/.turbo",
      "!**/*.min.js",
      "!**/pnpm-lock.yaml",
      "!**/preview",
      "!**/e2e"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "assist": { "actions": { "source": { "organizeImports": "on" } } },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "complexity": {
        "noExcessiveCognitiveComplexity": "off",
        "noForEach": "off",
        "noImportantStyles": "warn"
      },
      "correctness": {
        "noUnusedImports": "warn",
        "noUnusedVariables": "warn",
        "noUnusedFunctionParameters": "warn",
        "useExhaustiveDependencies": "off",
        "useHookAtTopLevel": "warn",
        "noChildrenProp": "off"
      },
      "style": {
        "noNonNullAssertion": "off",
        "useImportType": "warn",
        "useNodejsImportProtocol": "off",
        "useTemplate": "off",
        "noRestrictedImports": {
          "level": "error",
          "options": {
            "patterns": [
              {
                "group": "@/commands/**",
                "message": "Components must not import from the commands layer directly. Route through useExtraction or a dedicated hook."
              },
              {
                "group": "@/infrastructure/**",
                "message": "Components must not import from the infrastructure layer directly. Use queries or the store instead."
              }
            ]
          }
        }
      },
      "suspicious": {
        "noExplicitAny": "warn",
        "noConsole": "off",
        "noConfusingVoidType": "off",
        "noImplicitAnyLet": "off",
        "useIterableCallbackReturn": "off",
        "noArrayIndexKey": "warn",
        "noAssignInExpressions": "off"
      },
      "a11y": {
        "noStaticElementInteractions": "off",
        "useKeyWithClickEvents": "off",
        "useButtonType": "warn",
        "noSvgWithoutTitle": "warn",
        "useValidAriaProps": "warn",
        "noLabelWithoutControl": "warn",
        "useAriaPropsSupportedByRole": "warn"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "semicolons": "always",
      "trailingCommas": "es5"
    }
  },
  "css": {
    "parser": {
      "cssModules": true,
      "tailwindDirectives": true
    },
    "linter": {
      "enabled": false
    }
  },
  "overrides": [
    {
      "includes": [
        "apps/web/src/commands/**",
        "apps/web/src/queries/**",
        "apps/web/src/infrastructure/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/web/src/components/chat/**",
        "apps/web/src/components/commit/**",
        "apps/web/src/components/leaf/**",
        "apps/web/src/components/merge/**",
        "apps/web/src/components/tree-graph/merge-view/**"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": {
              "level": "error",
              "options": {
                "patterns": [
                  {
                    "group": "@/commands/**",
                    "message": "Components must not import from the commands layer directly. Route through useExtraction or a dedicated hook."
                  },
                  {
                    "group": "@/infrastructure/**",
                    "message": "Components must not import from the infrastructure layer directly. Use queries or the store instead."
                  },
                  {
                    "group": "@/lib/api/**",
                    "message": "Components must route lib/api reads/writes through a hook (hooks/) or query (queries/). Shared API types should be re-exported from @/types/api."
                  }
                ]
              }
            }
          }
        }
      }
    },
    {
      "includes": [
        "apps/web/src/components/chat/useExtraction.ts",
        "apps/web/src/components/chat/useGoldEdit.ts"
      ],
      "linter": {
        "rules": {
          "style": {
            "noRestrictedImports": "off"
          }
        }
      }
    }
  ]
}
