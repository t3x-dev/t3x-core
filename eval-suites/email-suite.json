{
  "id": "email-suite",
  "name": "Email Agent Test Suite",
  "description": "Tests for summarize + email agent workflow",
  "agent_id": "agent-demo",
  "cases": [
    {
      "id": "email-001",
      "name": "Basic summarize and email",
      "input": "Summarize the notes and email Alice a follow-up.",
      "context": {
        "meeting_notes": "Discussed timeline: ship v0 in 2 weeks. Risks: auth integration might slip. Action items: Bob to review auth flow, Alice to prepare demo.",
        "recipient": "alice@example.com"
      },
      "assertions": [
        {
          "id": "output-schema",
          "name": "Output has correct structure",
          "type": "json_schema",
          "target": "output",
          "assertion": {
            "schema": {
              "type": "object",
              "required": ["summary", "email"],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 20
                },
                "email": {
                  "type": "object",
                  "required": ["to", "subject", "body"],
                  "properties": {
                    "to": { "const": "alice@example.com" }
                  }
                }
              }
            }
          },
          "severity": "error"
        },
        {
          "id": "must-call-email",
          "name": "Must call email.send tool",
          "type": "trace_must_call",
          "target": "trace",
          "assertion": {
            "tool": "email.send"
          },
          "severity": "error"
        },
        {
          "id": "order-summarize-email",
          "name": "Summarize before sending email",
          "type": "trace_order",
          "target": "trace",
          "assertion": {
            "before": "summarize",
            "after": "email.send"
          },
          "severity": "error"
        }
      ]
    },
    {
      "id": "email-002",
      "name": "Summarize without email (no recipient)",
      "input": "Just summarize the meeting notes.",
      "context": {
        "meeting_notes": "Q4 planning: Focus on enterprise features. Budget approved for 2 new hires."
      },
      "assertions": [
        {
          "id": "output-has-summary",
          "name": "Output contains summary",
          "type": "json_schema",
          "target": "output",
          "assertion": {
            "schema": {
              "type": "object",
              "required": ["summary"],
              "properties": {
                "summary": {
                  "type": "string",
                  "minLength": 10
                }
              }
            }
          },
          "severity": "error"
        },
        {
          "id": "no-email-field",
          "name": "No email in output (no recipient provided)",
          "type": "not_contains",
          "target": "output",
          "assertion": {
            "value": "\"to\":"
          },
          "severity": "warning"
        }
      ]
    },
    {
      "id": "email-003",
      "name": "Follow-up email with subject detection",
      "input": "Summarize and send a follow-up to the team.",
      "context": {
        "meeting_notes": "Sprint retrospective: Velocity improved 20%. Team morale high. Next sprint focus on tech debt.",
        "recipient": "team@example.com"
      },
      "assertions": [
        {
          "id": "email-sent",
          "name": "Email tool was called",
          "type": "trace_must_call",
          "target": "trace",
          "assertion": {
            "tool": "email.send"
          },
          "severity": "error"
        },
        {
          "id": "subject-contains-follow",
          "name": "Subject contains 'Follow' or 'Summary'",
          "type": "regex",
          "target": "output",
          "assertion": {
            "pattern": "\"subject\":\\s*\"(Follow|Summary)"
          },
          "severity": "warning"
        }
      ]
    }
  ]
}
