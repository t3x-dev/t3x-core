# ================================
# Postgres (Docker dev)
# ================================
POSTGRES_USER=t3x
POSTGRES_PASSWORD=t3x_dev_password
POSTGRES_DB=t3x
POSTGRES_PORT=5432

# Core will read DATABASE_URL when running in Docker
DATABASE_URL=postgresql://t3x:t3x_dev_password@postgres:5432/t3x

# Optional: separate DB for n8n (future)
N8N_POSTGRES_DB=n8n

# ================================
# API Keys (optional, but required for LLM/NLP/Embedding features)
# ================================
# Used by t3x-core (Node server in t3x-cli)
ANTHROPIC_API_KEY=
GOOGLE_AI_STUDIO_KEY=
GOOGLE_CLOUD_NLP_KEY=

# ================================
# Runner Configuration (Engine → Runner → n8n flow)
# ================================
# n8n webhook base URL (for triggering workflows)
N8N_WEBHOOK_URL=http://localhost:5678/webhook

# Engine URL (for Runner to call back with results)
T3X_ENGINE_URL=http://localhost:8000

# Runner URL (for Engine to trigger runs)
T3X_RUNNER_URL=http://localhost:8080
