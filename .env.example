# ================================
# T3X Configuration
# ================================
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# ================================
# LLM Provider Keys
# ================================
# At least one provider key is required for semantic extraction and chat.
# Set in shell (recommended) or here:
#   export ANTHROPIC_API_KEY=sk-ant-...

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_AI_STUDIO_KEY=

# ================================
# First-Run Auth Behavior
# ================================
# Source development (`pnpm dev:api`, `pnpm dev:webui`) defaults AUTH_DISABLED=true
# when your shell does not already define it, so http://localhost:3000 opens
# directly into the app.
#
# To exercise the login flow during source development, export
# AUTH_DISABLED=false in the same shell before starting both dev processes.
# The source-dev launcher sets the default before the apps read `.env`.
#
# Docker and other self-hosted deployments keep auth on by default through
# docker-compose.yml and use the built-in username/password login at /login.
# Leave AUTH_DISABLED unset for the normal first-run experience.

AUTH_DISABLED=

# ================================
# Dangerous Development Tools
# ================================
# Enables the raw SQL inspector at /dev/db in the WebUI.
# This is ignored unless NODE_ENV=development. Leave unset unless you are
# deliberately inspecting a local database.

T3X_ENABLE_DEV_SQL=
