# ================================
# Web UI Configuration
# ================================
# URL of the T3X API server (Hono)
# In development: http://localhost:8000
# In production: your API server URL
NEXT_PUBLIC_API_URL=http://localhost:8000

# ================================
# Postgres (Docker dev)
# ================================
POSTGRES_USER=t3x
POSTGRES_PASSWORD=t3x_dev_password
POSTGRES_DB=t3x
POSTGRES_PORT=5432

# Core will read DATABASE_URL when running in Docker
DATABASE_URL=postgresql://t3x:t3x_dev_password@postgres:5432/t3x

# Optional: separate DB for n8n (future)
N8N_POSTGRES_DB=n8n

# ================================
# API Keys (optional, but required for LLM/NLP/Embedding features)
# ================================
# Used by t3x-core (Node server in t3x-cli)
ANTHROPIC_API_KEY=
GOOGLE_AI_STUDIO_KEY=
GOOGLE_CLOUD_NLP_KEY=

# ================================
# n8n Configuration (for Runner trace collection)
# ================================
# Generate API key from n8n: http://localhost:5678 → Settings → API
# Required for complete trace collection (tool_calls, tokens, etc.)
N8N_API_KEY=

# ================================
# API Authentication
# ================================
# Set to 'true' to disable all authentication (local/self-hosted development)
# Set to 'false' for SaaS mode (requires GitHub OAuth below)
AUTH_DISABLED=true

# T3X API Key (for WebUI → API authentication)
# Generate with: cd apps/api && pnpm seed:api-key
# Not needed when AUTH_DISABLED=true
NEXT_PUBLIC_T3X_API_KEY=

# ================================
# User Authentication (required when AUTH_DISABLED=false)
# ================================
# GitHub OAuth App — create at: https://github.com/settings/developers
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth — create at: https://console.cloud.google.com/apis/credentials
# Callback URL: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# NextAuth.js secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=

# NextAuth.js URL (defaults to http://localhost:3000 in dev)
# Set to your production URL in deployment (e.g., https://t3x.app)
# NEXTAUTH_URL=http://localhost:3000

# ================================
# Runner Configuration
# ================================
# Enable Runner UI (Deploy & Eval sidebar entry)
# Set to 'true' in Docker builds; omit for local development
# NEXT_PUBLIC_RUNNER_ENABLED=true
# Trace storage policy: always | on_failure | on_violation
# - always: Store full trace for all runs (recommended for development)
# - on_failure: Only store full trace when run fails (default, saves storage)
# - on_violation: Store full trace when evaluation has violations
TRACE_POLICY=always

