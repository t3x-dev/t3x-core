      "messages": [
        {
          "role": "user",
          "content": "What's the async HTTP client I should use?",
          "timestamp": "2025-10-06T16:15:00Z"
        },
        {
          "role": "assistant",
          "content": "Based on your notes, you should use `httpx` for async HTTP requests in Python. Never use `requests` in async functions as it blocks the event loop.",
          "timestamp": "2025-10-06T16:15:05Z"
        }
      ],
      "tags": [
        "quick-reference"
      ]
    }
