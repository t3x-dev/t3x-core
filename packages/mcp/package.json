{
  "name": "@t3x-dev/mcp-lib",
  "version": "0.1.7",
  "description": "T3X MCP server library — direct core import, 8 tools",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "dev": "tsup --watch",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@t3x-dev/api-client": "workspace:*",
    "@t3x-dev/core": "workspace:*",
    "@t3x-dev/yops": "workspace:*",
    "@t3x-dev/storage": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^2.1.0",
    "tsup": "^8.5.0",
    "typescript": "^5.7.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
