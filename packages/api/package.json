{
  "name": "@t3x-dev/api",
  "version": "0.1.3",
  "license": "Apache-2.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup src/index.ts src/app.ts --format esm --dts --clean",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs"
  },
  "dependencies": {
    "@hono/node-server": "^1.15.2",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^1.2.0",
    "@hono/zod-validator": "^0.7.6",
    "@mozilla/readability": "^0.6.0",
    "@scalar/hono-api-reference": "^0.9.30",
    "@t3x-dev/core": "workspace:*",
    "@t3x-dev/runner": "workspace:*",
    "@t3x-dev/storage": "workspace:*",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.38.3",
    "fflate": "^0.8.2",
    "hono": "^4.7.10",
    "jsdom": "^28.0.0",
    "mammoth": "^1.8.0",
    "nanoid": "^5.1.6",
    "pdf-parse": "^1.1.1",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^7.16.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/bcryptjs": "^3.0.0",
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.4",
    "@types/turndown": "^5.0.6",
    "dotenv": "^17.3.1",
    "embedded-postgres": "18.3.0-beta.16",
    "postgres": "^3.4.7",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.9"
  }
}
