{
  "name": "@t3x-dev/core",
  "version": "0.0.4",
  "description": "T3X Core - Deterministic semantic extraction, diff, and merge engine",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts --clean",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "bench": "vitest bench",
    "bench:watch": "vitest bench --watch",
    "test": "vitest run --exclude='**/golden/**' --exclude='**/compare-engines*'",
    "test:llm": "vitest run src/__tests__/golden/ src/__tests__/compare-engines.test.ts",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@t3x-dev/yops": "workspace:*",
    "@t3x-dev/yschema": "workspace:*",
    "js-yaml": "^4.1.1",
    "json-canonicalize": "^2.0.0",
    "nanoid": "^5.1.6",
    "undici": "^7.2.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^2.1.9",
    "dotenv": "^17.3.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "t3x",
    "semantic",
    "nlp",
    "diff",
    "merge",
    "extraction"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
