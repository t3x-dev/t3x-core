{
  "compilerOptions": {
    "target": "ES2021",
    "lib": ["ES2021", "ES2022.Intl"],
    "module": "CommonJS",
    "rootDir": "src",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Node",
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "dist",
    "node_modules",
    "docs",
    "examples",
    "tests",
    "schema",
    "configs",
    "src/__tests__"
  ]
}
