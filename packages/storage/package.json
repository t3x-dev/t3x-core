{
  "name": "@t3x-dev/storage",
  "version": "0.1.2",
  "description": "T3X Storage - PostgreSQL persistence layer with Drizzle ORM",
  "license": "Apache-2.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres.d.ts",
      "import": "./dist/postgres.js",
      "require": "./dist/postgres.js"
    },
    "./embedded": {
      "types": "./dist/embedded.d.ts",
      "import": "./dist/embedded.js",
      "require": "./dist/embedded.js"
    },
    "./supabase": {
      "types": "./dist/supabase.d.ts",
      "import": "./dist/supabase.js",
      "require": "./dist/supabase.js"
    },
    "./backup": {
      "types": "./dist/backup/index.d.ts",
      "import": "./dist/backup/index.js",
      "require": "./dist/backup/index.js"
    },
    "./seed/templates": {
      "types": "./dist/seed/templates.d.ts",
      "import": "./dist/seed/templates.js",
      "require": "./dist/seed/templates.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:changed": "vitest run --changed",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs"
  },
  "dependencies": {
    "@t3x-dev/core": "workspace:*",
    "drizzle-orm": "^0.38.3",
    "embedded-postgres": "^18.3.0-beta.16",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@swc/core": "^1.15.18",
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^2.1.9",
    "drizzle-kit": "^0.30.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "unplugin-swc": "^1.5.9",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "t3x",
    "storage",
    "drizzle",
    "postgres",
    "supabase"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "packages/storage"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
