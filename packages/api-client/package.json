{
  "name": "@t3x-dev/api-client",
  "version": "0.2.0",
  "description": "TypeScript client for T3X API",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src"
  },
  "dependencies": {
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t3x",
    "api",
    "client",
    "typescript"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x.git",
    "directory": "packages/api-client"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
