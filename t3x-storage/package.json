{
  "name": "@t3x/storage",
  "version": "0.1.0",
  "description": "T3X Storage - PostgreSQL persistence layer with Drizzle ORM",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@t3x/core": "file:../t3x-core",
    "@electric-sql/pglite": "^0.2.15",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "drizzle-kit": "^0.30.1",
    "typescript": "^5.9.3",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "t3x",
    "storage",
    "drizzle",
    "postgres",
    "pglite",
    "supabase"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/anthropics/t3x.git",
    "directory": "t3x-storage"
  }
}
