{
  "name": "@t3x-dev/local",
  "version": "0.4.0",
  "description": "T3X local entry package",
  "license": "Apache-2.0",
  "type": "module",
  "bin": {
    "t3x-local": "./dist/bin/t3x-local.js",
    "t3x": "./dist/bin/t3x.js",
    "t3x-mcp": "./dist/bin/t3x-mcp.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "scripts",
    "runtime-manifest.json"
  ],
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "apps/local"
  },
  "scripts": {
    "build": "tsup src/index.ts src/bin/t3x-local.ts src/bin/t3x.ts src/bin/t3x-mcp.ts --format esm --dts --clean",
    "dev": "tsx src/bin/t3x-local.ts",
    "prepare:runtime": "node ./scripts/prepare-runtime.mjs",
    "generate:runtime-manifest": "node ./scripts/generate-runtime-manifest.mjs",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs",
    "start": "node dist/bin/t3x-local.js start",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "postinstall": "node ./scripts/postinstall-download.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@hono/node-server": "^1.15.2",
    "@hono/node-ws": "^1.3.0",
    "@hono/zod-openapi": "^1.2.0",
    "@hono/zod-validator": "^0.7.6",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@mozilla/readability": "^0.6.0",
    "@scalar/hono-api-reference": "^0.9.30",
    "bcryptjs": "^3.0.3",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "drizzle-orm": "^0.38.3",
    "embedded-postgres": "^18.3.0-beta.16",
    "fflate": "^0.8.2",
    "hono": "^4.7.10",
    "js-yaml": "^4.1.1",
    "jsdom": "^28.0.0",
    "json-canonicalize": "^2.0.0",
    "mammoth": "^1.8.0",
    "nanoid": "^5.1.6",
    "ora": "^8.1.1",
    "pdf-parse": "^1.1.1",
    "pg": "^8.21.0",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "postgres": "^3.4.5",
    "table": "^6.9.0",
    "turndown": "^7.2.2",
    "turndown-plugin-gfm": "^1.0.2",
    "undici": "^7.16.0",
    "yaml": "^2.8.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=20.9.0"
  }
}
