{
  "name": "t3x-api-server",
  "version": "0.0.4",
  "license": "AGPL-3.0-only",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "seed:api-key": "tsx src/scripts/seed-api-key.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.15.2",
    "@t3x-dev/api": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "dotenv": "^17.3.1",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
