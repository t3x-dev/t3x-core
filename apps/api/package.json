{
  "name": "@t3x/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsup src/index.ts --format esm --dts --clean",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "lint": "biome lint src",
    "seed:api-key": "tsx src/scripts/seed-api-key.ts"
  },
  "dependencies": {
    "@hono/node-server": "^1.15.2",
    "@hono/zod-openapi": "^1.2.0",
    "@hono/zod-validator": "^0.7.6",
    "@scalar/hono-api-reference": "^0.9.30",
    "@t3x/core": "workspace:*",
    "@t3x/runner": "workspace:*",
    "@t3x/storage": "workspace:*",
    "fflate": "^0.8.2",
    "hono": "^4.7.10",
    "mammoth": "^1.8.0",
    "nanoid": "^5.1.6",
    "pdf-parse": "^1.1.1",
    "pino": "^9.14.0",
    "pino-pretty": "^11.3.0",
    "undici": "^7.16.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/pdf-parse": "^1.1.4",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  }
}
