{
  "name": "@t3x-dev/runner",
  "version": "0.0.1",
  "description": "T3X Runner - Grey-box agent evaluation, CI/CD, and workflow orchestration",
  "license": "MIT",
  "publishConfig": {
    "access": "restricted"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js"
    }
  },
  "bin": {
    "t3x-runner": "./dist/cli.js"
  },
  "files": [
    "dist",
    "eval-suites",
    "schemas"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "dev": "tsx watch --env-file=.env src/server.ts",
    "start": "node dist/server.js",
    "test": "vitest run --passWithNoTests",
    "schema:check": "node ./scripts/schema_check.mjs",
    "docker:build": "docker build -t t3x-runner .",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@t3x-dev/core": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.21.0",
    "js-yaml": "^4.1.1",
    "node-fetch": "^3.3.0",
    "pino": "^9.0.0",
    "pino-pretty": "^11.0.0",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.12.7",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "t3x",
    "agent",
    "eval",
    "runner",
    "greybox",
    "testing"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x.git",
    "directory": "apps/runner"
  }
}
