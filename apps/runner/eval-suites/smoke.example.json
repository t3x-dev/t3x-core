{
  "id": "smoke-example",
  "name": "Smoke Example Suite",
  "description": "Basic protocol smoke checks for suite/schema validation.",
  "agent_id": "agent-demo",
  "cases": [
    {
      "id": "smoke-001",
      "name": "tokyo-3day-under-800",
      "input": "Plan a 3-day Tokyo trip under $800.",
      "assertions": [
        {
          "id": "contains-budget",
          "name": "Output mentions budget",
          "type": "contains",
          "target": "output",
          "assertion": { "value": "budget" },
          "severity": "error"
        },
        {
          "id": "must-call-search",
          "name": "Must call search tool",
          "type": "trace_must_call",
          "target": "trace",
          "assertion": { "tool": "search" },
          "severity": "error"
        }
      ]
    }
  ]
}
