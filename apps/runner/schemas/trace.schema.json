{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://t3x.dev/schemas/trace.schema.json",
  "title": "T3X Trace (Phase 0)",
  "type": "object",
  "additionalProperties": true,
  "required": ["schema_version", "run_id", "ts", "agent_id", "events"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Protocol schema version (e.g. \"0.1\")."
    },
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this run."
    },
    "ts": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp for this trace envelope."
    },
    "agent_id": {
      "type": "string",
      "description": "Agent identifier."
    },
    "suite_id": {
      "type": "string",
      "description": "Optional suite identifier that produced this trace."
    },
    "case_name": {
      "type": "string",
      "description": "Optional case name within suite."
    },
    "commit_sha": {
      "type": "string",
      "description": "Optional git commit SHA for provenance."
    },
    "env": {
      "type": "object",
      "additionalProperties": true,
      "description": "Optional environment/provenance metadata."
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/event" },
      "description": "Ordered list of trace events."
    }
  },
  "$defs": {
    "event": {
      "type": "object",
      "additionalProperties": true,
      "required": ["type", "ts", "payload"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["agent_input", "agent_output", "llm_call", "tool_call", "error"]
        },
        "ts": {
          "type": "string",
          "format": "date-time"
        },
        "payload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    }
  }
}
