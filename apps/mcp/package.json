{
  "name": "@t3x-dev/mcp",
  "version": "0.4.1",
  "description": "T3X MCP Server — semantic version control tools for AI agents",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "apps/mcp"
  },
  "keywords": [
    "t3x",
    "mcp",
    "semantic",
    "version-control",
    "ai",
    "knowledge-management"
  ],
  "type": "module",
  "bin": {
    "t3x-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "publishConfig": {
    "access": "restricted"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "test": "vitest run --passWithNoTests",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@t3x-dev/mcp-lib": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "embedded-postgres": "18.3.0-beta.17",
    "js-yaml": "^4.1.1",
    "json-canonicalize": "^2.0.0",
    "nanoid": "^5.1.6",
    "pg": "^8.21.0",
    "postgres": "^3.4.9",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.1",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  }
}
