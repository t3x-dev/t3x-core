{
  "name": "@t3x-dev/cli",
  "version": "0.5.0",
  "description": "T3X Command Line Interface",
  "type": "module",
  "bin": {
    "t3x": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src",
    "prepack": "node ../../tools/rewrite-workspace-package-json.mjs",
    "postpack": "node ../../tools/restore-package-json.mjs"
  },
  "dependencies": {
    "@t3x-dev/api-client": "workspace:*",
    "@t3x-dev/core": "workspace:*",
    "@t3x-dev/yops": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "js-yaml": "^4.1.1",
    "json-canonicalize": "^2.0.0",
    "nanoid": "^5.1.6",
    "ora": "^8.1.1",
    "table": "^6.9.0",
    "yaml": "^2.8.3",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "8.0.16",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t3x",
    "cli",
    "semantic",
    "version-control",
    "ai"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "restricted"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "apps/cli"
  }
}
