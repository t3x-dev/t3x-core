{
  "name": "@t3x-dev/cli",
  "version": "0.1.0",
  "private": true,
  "description": "T3X Command Line Interface",
  "type": "module",
  "bin": {
    "t3x": "./dist/index.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "test": "vitest run --passWithNoTests",
    "lint": "biome lint src"
  },
  "dependencies": {
    "@t3x-dev/api-client": "workspace:*",
    "@t3x-dev/core": "workspace:*",
    "@t3x-dev/yops": "workspace:*",
    "@t3x-dev/yschema": "workspace:*",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "ora": "^8.1.1",
    "table": "^6.9.0",
    "yaml": "^2.8.3"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "t3x",
    "cli",
    "semantic",
    "version-control",
    "ai"
  ],
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/t3x-dev/t3x-core.git",
    "directory": "apps/cli"
  }
}
