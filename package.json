{
  "name": "t3x",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "description": "T3X - Semantic extraction, diff, and merge for conversational AI",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "prepare": "sh tools/hooks/install-hooks.sh",
    "build": "turbo run build",
    "build:core": "turbo run build --filter=@t3x-dev/core",
    "build:storage": "turbo run build --filter=@t3x-dev/storage",
    "build:webui": "turbo run build --filter=t3x-webui",
    "build:local": "turbo run build --filter=@t3x-dev/local",
    "build:local-runtime": "pnpm --filter @t3x-dev/local prepare:runtime && pnpm --filter @t3x-dev/local generate:runtime-manifest",
    "build:runner": "turbo run build --filter=@t3x-dev/runner",
    "build:api": "turbo run build --filter=@t3x-dev/api",
    "build:api-server": "turbo run build --filter=t3x-api-server",
    "build:yops": "turbo run build --filter=@t3x-dev/yops",
    "build:yschema": "turbo run build --filter=@t3x-dev/yschema",
    "test:api": "turbo run test --filter=@t3x-dev/api",
    "test:yschema": "turbo run test --filter=@t3x-dev/yschema",
    "clean": "turbo run clean",
    "test": "node --test tools/__tests__/sourceDevAuthDefaults.test.mjs tools/__tests__/releaseSurface.test.mjs tools/__tests__/standardsMatrix.test.mjs tools/__tests__/releasePr.test.mjs tools/__tests__/productRelease.test.mjs tools/__tests__/issueTemplates.test.mjs && turbo run test",
    "test:core": "turbo run test --filter=@t3x-dev/core",
    "test:storage": "turbo run test --filter=@t3x-dev/storage",
    "test:webui": "turbo run test --filter=t3x-webui",
    "test:webui:no-deps": "pnpm --filter t3x-webui exec vitest run",
    "test:runner": "turbo run test --filter=@t3x-dev/runner",
    "test:yops": "turbo run test --filter=@t3x-dev/yops",
    "screenshots:demo": "node tools/screenshot-demo.mjs",
    "typecheck": "turbo run typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:release-surface": "node tools/check-release-surface.mjs",
    "check:release-pr": "node tools/check-release-pr.mjs",
    "standards:validate": "node tools/check-standards-matrix.mjs",
    "dev": "turbo run dev",
    "dev:webui": "node tools/dev-source-runner.mjs webui",
    "dev:api": "node tools/dev-source-runner.mjs api",
    "dev:api:persistent": "pnpm --filter t3x-api-server dev:persistent",
    "dev:agent": "turbo run dev --filter=agent-demo",
    "e2e": "pnpm e2e:stop && node tools/dev-package-runner.mjs webui pnpm build && (node tools/dev-package-runner.mjs api node apps/api/dist/index.js & pnpm --filter t3x-webui start & wait)",
    "e2e:api": "(lsof -ti:8000 | xargs kill -9 2>/dev/null; true) && node tools/dev-package-runner.mjs api pnpm build && node tools/dev-package-runner.mjs api node apps/api/dist/index.js",
    "e2e:webui": "(lsof -ti:3000 | xargs kill -9 2>/dev/null; true) && node tools/dev-package-runner.mjs webui pnpm --filter t3x-webui build && pnpm --filter t3x-webui start",
    "e2e:stop": "(lsof -ti:8000 | xargs kill -9 2>/dev/null; true); (lsof -ti:3000 | xargs kill -9 2>/dev/null; true)",
    "stop:api": "lsof -ti:8000 | xargs kill -TERM 2>/dev/null || echo 'API not running'",
    "stop:webui": "lsof -ti:3000 | xargs kill -TERM 2>/dev/null || echo 'WebUI not running'",
    "docker:up": "docker compose up",
    "docker:up:all": "docker compose --profile runner --profile n8n up",
    "docker:up:n8n": "docker compose --profile n8n up",
    "docker:up:runner": "docker compose --profile runner up",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "changeset": "changeset",
    "verify:versions": "node tools/verify-versions.mjs",
    "verify:versions:no-manifest": "node tools/verify-versions.mjs --no-manifest",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "publish-packages": "pnpm verify:versions && pnpm build && node tools/publish-package-tarballs.mjs",
    "publish-runtime-release": "node tools/publish-runtime-release.mjs",
    "publish-release": "pnpm publish-runtime-release && pnpm publish-packages",
    "smoke:local-install": "node tools/smoke-local-install.mjs"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@embedded-postgres/darwin-arm64",
      "@embedded-postgres/darwin-x64",
      "@embedded-postgres/linux-arm64",
      "@embedded-postgres/linux-x64",
      "@swc/core"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/js-yaml": "^4.0.9",
    "dotenv-cli": "^11.0.0",
    "js-yaml": "^4.1.1",
    "turbo": "^2.7.2"
  }
}
