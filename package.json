{
  "name": "t3x",
  "version": "0.1.0",
  "private": true,
  "description": "T3X - Semantic extraction, diff, and merge for conversational AI",
  "workspaces": [
    "t3x-core",
    "t3x-core/sdk/javascript",
    "t3x-storage",
    "t3x-webui",
    "t3x-runner",
    "agent-demo"
  ],
  "scripts": {
    "build": "npm run build:core && npm run build:storage && npm run build:webui",
    "build:core": "npm run build -w @t3x/core",
    "build:storage": "npm run build -w @t3x/storage",
    "build:webui": "npm run build -w t3x-webui",
    "build:runner": "npm run build -w @t3x/runner",
    "clean": "npm run clean -w @t3x/core",
    "test": "npm run test:core && npm run test:storage",
    "test:core": "npm run test -w @t3x/core",
    "test:storage": "npm run test -w @t3x/storage",
    "test:all": "npm run test:core && npm run test:storage",
    "lint": "npm run lint -w @t3x/core",
    "runner:dev": "npm run dev -w @t3x/runner",
    "runner:start": "npm run start -w @t3x/runner",
    "agent-demo:dev": "npm run dev -w agent-demo",
    "docker:up": "docker-compose up",
    "docker:up:n8n": "docker-compose --profile n8n up",
    "docker:down": "docker-compose down",
    "docker:build": "docker-compose build"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
