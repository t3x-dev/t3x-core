{
  "name": "t3x",
  "version": "0.1.0",
  "private": true,
  "description": "T3X - Semantic extraction, diff, and merge for conversational AI",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "build": "turbo run build",
    "build:core": "turbo run build --filter=@t3x-dev/core",
    "build:storage": "turbo run build --filter=@t3x-dev/storage",
    "build:webui": "turbo run build --filter=t3x-webui",
    "build:runner": "turbo run build --filter=@t3x-dev/runner",
    "build:api": "turbo run build --filter=@t3x-dev/api",
    "clean": "turbo run clean",
    "test": "turbo run test",
    "test:core": "turbo run test --filter=@t3x-dev/core",
    "test:storage": "turbo run test --filter=@t3x-dev/storage",
    "test:webui": "turbo run test --filter=t3x-webui",
    "test:runner": "turbo run test --filter=@t3x-dev/runner",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "dev": "turbo run dev",
    "dev:webui": "turbo run dev --filter=t3x-webui",
    "dev:api": "turbo run dev --filter=@t3x-dev/api",
    "dev:agent": "turbo run dev --filter=agent-demo",
    "stop:api": "lsof -ti:8000 | xargs kill -TERM 2>/dev/null || echo 'API not running'",
    "stop:webui": "lsof -ti:3000 | xargs kill -TERM 2>/dev/null || echo 'WebUI not running'",
    "docker:up": "docker compose up",
    "docker:up:all": "docker compose --profile runner --profile n8n up",
    "docker:up:n8n": "docker compose --profile n8n up",
    "docker:up:runner": "docker compose --profile runner up",
    "docker:down": "docker compose down",
    "docker:build": "docker compose build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "publish-packages": "pnpm build && changeset publish"
  },
  "engines": {
    "node": ">=20.9.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@embedded-postgres/darwin-arm64",
      "@embedded-postgres/darwin-x64",
      "@embedded-postgres/linux-arm64",
      "@embedded-postgres/linux-x64"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.10",
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.7.2"
  }
}
